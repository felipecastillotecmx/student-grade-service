  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response time is under 2000 ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "const contentType = pm.response.headers.get('Content-Type') || '';",
                  "pm.test('Content-Type is JSON', function () {",
                  "    pm.expect(contentType.toLowerCase()).to.include('application/json');",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.test('status field exists', function () {",
                  "    pm.expect(body).to.have.property('status');",
                  "});",
                  "",
                  "pm.test('status is UP', function () {",
                  "    pm.expect(body.status).to.eql('UP');",
                  "});",
                  "",
                  "pm.test('service field exists', function () {",
                  "    pm.expect(body).to.have.property('service');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "Valida que el servicio esté levantado y responda correctamente."
          },
          "response": []
        }
      ]
    },
